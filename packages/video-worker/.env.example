# Required
WORKER_SECRET=change-me-to-a-long-random-string-min-16-chars
DATABASE_URL=postgresql://user:pass@host:5432/db

# AWS / R2 / MinIO storage
AWS_BUCKET_NAME=tutly-prod
AWS_BUCKET_REGION=auto
AWS_ACCESS_KEY=...
AWS_SECRET_KEY=...
AWS_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
AWS_S3_PUBLIC_URL=https://video.yourdomain.com

# Redis (local on the VPS)
REDIS_URL=redis://127.0.0.1:6379

# ffmpeg discovery — leave blank if it's on $PATH
# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe

# Worker tuning
PORT=4400
WORK_DIR=/var/lib/tutly-video-worker
CONCURRENCY=1
LOG_LEVEL=info
