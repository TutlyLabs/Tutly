{
  "name": "@tutly/utils",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./cn": {
      "types": "./src/cn.ts",
      "default": "./src/cn.ts"
    },
    "./dayjs": {
      "types": "./src/dayjs.ts",
      "default": "./src/dayjs.ts"
    }
  },
  "scripts": {
    "lint": "eslint \"src/**/*.ts*\" --max-warnings 0",
    "lint:fix": "eslint \"src/**/*.ts*\" --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tutly/eslint-config": "workspace:*",
    "@tutly/typescript-config": "workspace:*",
    "eslint": "^9.39.2",
    "typescript": "5.9.3"
  }
}
