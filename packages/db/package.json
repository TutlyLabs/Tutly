{
  "name": "@tutly/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./prisma/generated/client.ts",
      "default": "./prisma/generated/client.ts"
    },
    "./browser": {
      "types": "./prisma/generated/browser.ts",
      "default": "./prisma/generated/browser.ts"
    },
    "./schema": "./prisma/schema.prisma"
  },
  "scripts": {
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "lint": "eslint \"src/**/*.ts*\" --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.1.0",
    "dotenv": "^17.0.0"
  },
  "devDependencies": {
    "@tutly/eslint-config": "workspace:*",
    "@tutly/typescript-config": "workspace:*",
    "eslint": "^9.39.2",
    "prisma": "^7.1.0",
    "typescript": "5.9.3"
  }
}
