{
  "name": "@tutly/api-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./trpc": {
      "types": "./src/trpc.ts",
      "default": "./src/trpc.ts"
    },
    "./auth": {
      "types": "./src/auth.ts",
      "default": "./src/auth.ts"
    }
  },
  "scripts": {
    "lint": "eslint \"src/**/*.ts*\" --max-warnings 0",
    "lint:fix": "eslint \"src/**/*.ts*\" --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@trpc/client": "11.8.0",
    "superjson": "2.2.6"
  },
  "devDependencies": {
    "@tutly/eslint-config": "workspace:*",
    "@tutly/typescript-config": "workspace:*",
    "eslint": "^9.39.2",
    "typescript": "5.9.3"
  }
}
