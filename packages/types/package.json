{
  "name": "@tutly/types",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./api": {
      "types": "./src/api.ts",
      "default": "./src/api.ts"
    }
  },
  "scripts": {
    "lint": "eslint \"src/**/*.ts*\" --max-warnings 0",
    "lint:fix": "eslint \"src/**/*.ts*\" --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@trpc/server": "11.8.0",
    "@tutly/api": "workspace:*"
  },
  "devDependencies": {
    "@tutly/eslint-config": "workspace:*",
    "@tutly/typescript-config": "workspace:*",
    "eslint": "^9.39.2",
    "typescript": "5.9.3"
  }
}
