{
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "env": ["VITE_API_URL", "MODE", "NODE_ENV"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["VITE_API_URL", "MODE", "NODE_ENV"]
    },
    "cap:sync": {
      "cache": false,
      "dependsOn": ["build"]
    }
  }
}
