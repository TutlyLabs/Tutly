TEST_RUNNER_PORT=3010
TEST_RUNNER_SECRET=change-me-to-a-long-random-string-32-chars-min
WEB_BASE_URL=http://web:3000

WORK_DIR=/tmp/tutly-runner
WORK_DIR_HOST=/tmp/tutly-runner
RUNTIME_DIR=/app/apps/runner-orchestrator/runtime

USE_DOCKER=true
JEST_IMAGE=ghcr.io/tutlylabs/tutly-jest-runner:latest

CONCURRENCY=2
JOB_TIMEOUT_MS=120000
JOB_MEMORY_MB=512
JOB_CPU_LIMIT=1.0
JOB_PIDS_LIMIT=128

DATABASE_URL=postgres://postgres:postgres@db:5432/tutly

LOG_LEVEL=info
