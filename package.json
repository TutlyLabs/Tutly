{
  "name": "@tutly/root",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x",
    "pnpm": ">=9.6.0"
  },
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "dev": "turbo watch dev --continue",
    "dev:web": "turbo watch dev -F web",
    "dev:landing": "turbo watch dev -F landing",
    "dev:video-worker": "turbo watch dev -F video-worker",
    "format": "turbo run format --continue -- --cache --cache-location .cache/.prettiercache",
    "format:fix": "turbo run format --continue -- --write --cache --cache-location .cache/.prettiercache",
    "lint": "turbo run lint --continue",
    "lint:fix": "turbo run lint --continue -- --fix",
    "lint:ws": "pnpm dlx sherif@latest",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "postinstall": "rm -rf node_modules/wrap-ansi/node_modules/string-width 2>/dev/null; pnpm lint:ws",
    "typecheck": "turbo run typecheck",
    "ui-add": "turbo run ui-add",
    "update:deps": "pnpm dlx npm-check-updates --deep --target latest -u && pnpm install"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@turbo/gen": "^2.6.3",
    "@tutly/prettier-config": "workspace:*",
    "prettier": "catalog:",
    "turbo": "^2.6.3",
    "typescript": "catalog:"
  },
  "prettier": "@tutly/prettier-config",
  "resolutions": {
    "prettier": "3.5.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "sharp"
    ],
    "overrides": {
      "@types/minimatch": "5.1.2",
      "@isaacs/brace-expansion": "^5.0.1",
      "@xmldom/xmldom": "^0.9.10",
      "basic-ftp": "^5.2.2",
      "bn.js": "^4.12.3",
      "defu": "^6.1.5",
      "dompurify": "^3.4.3",
      "fast-uri": "^3.1.2",
      "fast-xml-parser": "^5.8.0",
      "flatted": "^3.4.2",
      "follow-redirects": "^1.16.0",
      "handlebars": "^4.7.9",
      "immutable": "^5.1.5",
      "ip-address": "^10.2.0",
      "markdown-it": "^14.1.1",
      "path-to-regexp": "^8.4.2",
      "protobufjs": "^7.5.8",
      "qs": "^6.14.2",
      "tar": "^7.5.15",
      "undici": "^7.18.2",
      "uuid": "^11.1.1",
      "webpack": "^5.104.1"
    }
  }
}